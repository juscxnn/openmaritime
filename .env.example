# OpenMaritime Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://openmaritime:openmaritime@localhost:5432/openmaritime

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
LLAMA_MODEL=llama3.1:70b
USE_LOCAL_LLAMA=true

# RAG / Embeddings
ENABLE_RAG=true
EMBEDDING_MODEL=nomic-embed-text

# Plugin API Keys (get from respective services)
RIGHTSHIP_API_KEY=
MARINETRAFFIC_API_KEY=
VESON_API_TOKEN=
VESON_API_URL=https://api.veslink.com
SIGNAL_OCEAN_API_KEY=
SIGNAL_OCEAN_API_URL=https://api.signalocean.com
ZERONORTH_API_KEY=
ZERONORTH_API_URL=https://api.zeronorth.com
IDWAL_API_KEY=
IDWAL_API_URL=https://api.idwal.com
ORBITMI_API_KEY=
ORBITMI_API_URL=https://api.orbitmi.com
ABAIXA_API_KEY=
ABAIXA_API_URL=https://api.abaixa.io
PORTCALL_API_KEY=
PORTCALL_API_URL=https://api.portcall.ai

# Email Sync (Gmail)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Kafka (High-volume ingestion)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FIXTURES_TOPIC=fixtures

# Whisper (Voice)
WHISPER_MODEL=whisper

# Notifications
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#chartering
APP_URL=http://localhost:3000

# SSO / Enterprise (SAML or OIDC)
SSO_ENABLED=false
SSO_TYPE=saml  # or oidc
SSO_IDP_METADATA_URL=
SSO_IDP_ENTITY_ID=
SSO_IDP_SSO_URL=
SSO_SP_ENTITY_ID=openmaritime
SSO_CALLBACK_URL=/api/v1/auth/sso/callback
SSO_OIDC_ISSUER=
SSO_OIDC_CLIENT_ID=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
