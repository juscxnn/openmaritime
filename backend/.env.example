# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/openmaritime
SQL_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Authentication
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OAuth (Gmail, Outlook, etc.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# Ollama (Local AI)
OLLAMA_BASE_URL=http://localhost:11434
WHISPER_MODEL=whisper
LLAMA_MODEL=llama3.1:70b
USE_LOCAL_LLAMA=true

# OpenAI / Anthropic (Optional - for cloud fallback)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# AWS (for S3 voice notes)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=openmaritime-voice-notes
AWS_REGION=us-east-1
